{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Backend: Start Flask Server",
            "type": "shell",
            "command": "python",
            "args": [
                "app.py"
            ],
            "cwd": "${workspaceFolder}/backend",
            "isBackground": false,
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "new",
                "showReuseMessage": true
            }
        },
        {
            "label": "Setup: Install Dependencies",
            "type": "shell",
            "command": "pip",
            "args": [
                "install",
                "-r",
                "requirements.txt"
            ],
            "cwd": "${workspaceFolder}",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "new"
            }
        },
        {
            "label": "Setup: Create Virtual Environment",
            "type": "shell",
            "command": "python",
            "args": [
                "-m",
                "venv",
                "venv"
            ],
            "cwd": "${workspaceFolder}",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "new"
            }
        },
        {
            "label": "Test: Run Backend Tests",
            "type": "shell",
            "command": "python",
            "args": [
                "-m",
                "pytest",
                "."
            ],
            "cwd": "${workspaceFolder}/backend",
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "new"
            }
        },
        {
            "label": "Test: Generate 25 MCQs",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "Invoke-WebRequest -Uri http://localhost:5000/api/generate-mcqs -Method Post -ContentType 'application/json' -Body '{\"topic\":\"Banking\",\"num_questions\":25,\"difficulty\":\"medium\"}' | Select-Object -ExpandProperty Content"
            ],
            "cwd": "${workspaceFolder}",
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "new"
            }
        }
    ]
}
